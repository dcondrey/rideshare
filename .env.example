# ─── Required ────────────────────────────────────────────────────────────────

# Public URL where this app is served (used in magic-link emails).
APP_URL=http://localhost:3000

# Strong random secret used to sign session cookies and magic-link tokens.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# Strong random secret used to HMAC attendee emails in the allowlist.
# Generate with:  openssl rand -hex 32
# WARNING: rotating this requires re-importing the attendee CSV.
ALLOWLIST_SALT=

# Comma-separated list of admin email addresses. Only these accounts can
# access /admin (after they sign in via the normal magic-link flow).
ADMIN_EMAILS=organizer@example.com

# ─── Email — pick ONE of the two options below ───────────────────────────────

# Option A: Resend (https://resend.com) — recommended. Free tier covers ~3k/mo.
RESEND_API_KEY=
EMAIL_FROM="Rideshare <noreply@example.com>"

# Option B: SMTP — bring your own server (Postmark, SES, Mailgun, Gmail, …)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false   # true = implicit TLS on port 465; false = STARTTLS on 587

# ─── Optional ────────────────────────────────────────────────────────────────

# HTTP port. Default 3000.
PORT=3000

# SQLite file path. Default ./data/app.db.
# In Docker: mount a volume to /data and set DATABASE_PATH=/data/app.db.
DATABASE_PATH=./data/app.db

# Magic-link rate limit: max sends per email per hour. Default 5.
MAGIC_LINK_RATE_LIMIT=5

# Session lifetime in days. Default 14.
SESSION_LIFETIME_DAYS=14

# Trust proxy headers (X-Forwarded-Proto, X-Forwarded-For)? Default false.
# Set to true if running behind a reverse proxy (Cloudflare, nginx, Railway).
TRUST_PROXY=false
